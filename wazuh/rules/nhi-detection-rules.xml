  <rule id="100804" level="10">
    <if_sid>80700,530</if_sid>
    <match>NPM_TOKEN</match>
    <description>NHI: NPM authentication token detected</description>
    <mitre>
      <id>T1552.007</id>
    </mitre>
    <group>nhi_cicd_npm,</group>
  </rule>

  <!-- ACTIONS_RUNTIME_TOKEN -->
  <rule id="100805" level="10">
    <if_sid>80700,530</if_sid>
    <match>ACTIONS_RUNTIME_TOKEN</match>
    <description>NHI: GitHub Actions runtime token detected</description>
    <mitre>
      <id>T1552.007</id>
    </mitre>
    <group>nhi_cicd_github,</group>
  </rule>

</group>

<!-- ================================================= -->
<!-- GROUP 5: AI AGENT ANOMALIES                       -->
<!-- Rule IDs: 100850-100899                           -->
<!-- Upgraded to production-grade: 2026-02-15          -->
<!-- ================================================= -->
<group name="nhi,ai_agent,">

  <!-- AI agent framework spawning shell subprocess (match auditd comm= and execve args) -->
  <rule id="100850" level="10">
    <if_sid>80792</if_sid>
    <match type="pcre2">comm="(python3?|node|langchain|autogen|crewai|agent|llama|vllm|ollama)"</match>
    <match type="pcre2">a\d+="?(/bin/)?(bash|sh|zsh|dash|cmd|powershell|pwsh)"?\s</match>
    <description>NHI: AI agent framework spawning shell subprocess</description>
    <mitre>
      <id>T1059</id>
      <id>T1059.004</id>
    </mitre>
    <group>nhi_ai_shell,pci_dss_10.2.7,</group>
  </rule>

  <!-- AI agent shell executing sensitive commands -->
  <rule id="100855" level="12">
    <if_sid>100850</if_sid>
    <match type="pcre2">curl.*169\.254|wget.*169\.254|curl.*metadata|nc\s+-|ncat\s+|ssh\s+|scp\s+|rsync\s+</match>
    <description>NHI: AI agent shell executing network/exfiltration command</description>
    <mitre>
      <id>T1059</id>
      <id>T1041</id>
    </mitre>
    <group>nhi_ai_shell_network,</group>
  </rule>

  <!-- AI process accessing credential files (uses auditd file watches, not FIM,
       since FIM cannot report which process accessed a file) -->
  <rule id="100851" level="12">
    <if_sid>80700,80790</if_sid>
    <match type="pcre2">comm="(python3?|node|langchain|autogen|crewai|agent|llama|vllm|ollama)"</match>
    <match type="pcre2">name="[^"]*(\.env|credentials|\.aws/|\.kube/config|\.vault-token|\.npmrc|\.docker/config\.json|\.git-credentials|id_rsa|id_ed25519|\.pem|\.key|\.p12|\.pfx|service[-_]?account.*\.json|\.mcp/|tool[-_]?config)"</match>
    <description>NHI: AI agent accessing credential/config file</description>
    <mitre>
      <id>T1552.001</id>
      <id>T1552.004</id>
    </mitre>
    <group>nhi_ai_cred_access,pci_dss_8.2.1,</group>
  </rule>

  <!-- Prompt injection detection with comprehensive patterns -->
  <rule id="100852" level="10">
    <if_sid>31100,31101</if_sid>
    <match type="pcre2">(?i)ignore\s+(all\s+)?previous|disregard\s+(all\s+)?instructions|system\s*prompt|jailbreak|you\s+are\s+now|act\s+as\s+(a\s+)?root|reveal\s+(your\s+)?(system|secret|hidden)|override\s+(safety|security|filter)|bypass\s+(filter|restriction|guard)|execute\s+(this\s+)?command|&lt;\|system\|&gt;|&lt;!--\s*inject|do\s+not\s+follow\s+(your|the)\s+rules|pretend\s+you\s+are|output\s+(your\s+)?instructions</match>
    <description>NHI: Prompt injection attempt detected in web request</description>
    <mitre>
      <id>T1059</id>
      <id>T1190</id>
    </mitre>
    <group>nhi_ai_prompt_injection,</group>
  </rule>

  <!-- Prompt injection detection via custom AI agent decoder (Flask/custom log formats) -->
  <rule id="100860" level="10">
    <decoded_as>nhi-ai-agent</decoded_as>
    <match type="pcre2">(?i)ignore\s+(all\s+)?previous|disregard\s+(all\s+)?instructions|system\s*prompt|jailbreak|you\s+are\s+now|act\s+as\s+(a\s+)?root|reveal\s+(your\s+)?(system|secret|hidden)|override\s+(safety|security|filter)|bypass\s+(filter|restriction|guard)|execute\s+(this\s+)?command</match>
    <description>NHI: Prompt injection attempt detected via AI agent logs</description>
    <mitre>
      <id>T1059</id>
      <id>T1190</id>
    </mitre>
    <group>nhi_ai_prompt_injection,</group>
  </rule>

  <!-- Elevated prompt injection - targeting credential extraction -->
  <rule id="100856" level="14">
    <if_sid>100852,100860</if_sid>
    <match type="pcre2">(?i)(fetch|read|cat|access|show|print|display).{0,30}(credential|password|secret|token|key|\.env|/etc/passwd|/etc/shadow|aws.*key|api.*key)</match>
    <description>NHI: Prompt injection targeting credential extraction - CRITICAL</description>
    <mitre>
      <id>T1059</id>
      <id>T1552.001</id>
    </mitre>
    <group>nhi_ai_prompt_injection_cred,</group>
  </rule>

