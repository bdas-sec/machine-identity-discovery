<!-- ================================================= -->
<!-- GROUP 8: SPIFFE/SPIRE WORKLOAD IDENTITY           -->
<!-- Rule IDs: 101000-101099                           -->
<!-- Attack surface based on Eviatar Gerzi's (CyberArk)-->
<!-- "The Machine with Many Faces" research (2026)     -->
<!-- ================================================= -->
<group name="nhi,spiffe_spire,">

  <!-- ===== SPIRE Socket & SVID Access (101000-101019) ===== -->

  <!-- SPIRE Workload API socket access
       Detection via: FIM (550/554) for file creation/deletion of socket,
       auditd (80700-80799) for socket connect() syscalls, or SPIRE Agent
       logs referencing socket paths.
       NOTE: FIM alone won't catch socket connections — add auditd rule:
         -w /tmp/spire-agent/public/api.sock -p rwa -k spire_socket
       Or use syscheck <directories> on the socket parent directory. -->
  <rule id="101000" level="8">
    <if_sid>550,554,80700,80790</if_sid>
    <match type="pcre2">spire-agent.*api\.sock|SPIFFE_ENDPOINT_SOCKET|/run/spire/sockets/agent\.sock</match>
    <description>NHI-SPIRE: Workload API socket access detected</description>
    <mitre>
      <id>T1552.007</id>
      <id>T1078.001</id>
    </mitre>
    <group>nhi_spire_socket,</group>
  </rule>

  <!-- SPIRE socket access from scripting/exploitation tool -->
  <rule id="101001" level="12">
    <if_sid>101000</if_sid>
    <field name="process_name" type="pcre2">curl|wget|python3?|ruby|perl|nc|ncat|grpcurl|go</field>
    <description>NHI-SPIRE: Workload API access from scripting tool - $(process_name)</description>
    <mitre>
      <id>T1552.007</id>
      <id>T1059</id>
    </mitre>
    <group>nhi_spire_socket_suspicious,</group>
  </rule>

  <!-- X.509 SVID private key extraction -->
  <rule id="101002" level="14">
    <if_sid>550,554</if_sid>
    <match type="pcre2">svid\.key|svid\.pem|/opt/spire/data/agent/.*\.(key|pem)|FetchX509SVID.*private</match>
    <description>NHI-SPIRE: X.509 SVID private key extraction attempt</description>
    <mitre>
      <id>T1552.004</id>
      <id>T1552.001</id>
    </mitre>
    <group>nhi_spire_svid_theft,</group>
  </rule>

  <!-- Burst of SVID requests — credential harvesting
       FIX: Removed <same_source_ip/> (meaningless for local Unix domain socket access).
       Lowered from level 14 to 12 — precise detection is now in script-based rule 101008. -->
  <rule id="101003" level="12" frequency="10" timeframe="60">
    <if_matched_group>nhi_spire_socket</if_matched_group>
    <description>NHI-SPIRE: Burst of SVID requests - credential harvesting likely (see 101008 for confirmed detection)</description>
    <mitre>
      <id>T1552.007</id>
      <id>T1041</id>
    </mitre>
    <group>nhi_spire_svid_harvest,</group>
  </rule>

  <!-- SVID fetch/issuance event from SPIRE Agent logs (base for PID correlation)
       NOTE: Requires SPIRE Agent log_level=DEBUG to capture PID on SVID fetch.
       Actual SPIRE msg values: "Fetched JWT SVID", "Fetched X.509 SVID",
       "No identity issued", "SVID updated". Also matches audit log method names.
       FIX: Lowered to level 3 correlation base with no_log — this fires frequently
       under normal operation and is only useful as a trigger for rules 101005/101006. -->
  <rule id="101004" level="3">
    <decoded_as>nhi-spire-agent</decoded_as>
    <match type="pcre2">Fetched\s+(JWT|X\.509)\s+SVID|SVID\s+(updated|rotated)|No identity issued|FetchX509SVID|FetchJWTSVID|FetchX509BundlesStream</match>
    <description>NHI-SPIRE: SVID fetch/issuance event - PID $(id) identity $(url)</description>
    <options>no_log</options>
    <group>nhi_spire_svid_fetch,</group>
  </rule>

  <!-- Multiple SVID requests from same PID — potential harvesting or abuse
       FIX: Increased frequency threshold from 5 to 10 to reduce false positives.
       For precise detection see script-based rule 101008. -->
  <rule id="101005" level="12" frequency="10" timeframe="120">
    <if_matched_group>nhi_spire_svid_fetch</if_matched_group>
    <same_field>id</same_field>
    <description>NHI-SPIRE: Multiple SVID requests from same PID $(id) - potential harvesting (see 101008 for confirmed detection)</description>
    <mitre>
      <id>T1552.007</id>
      <id>T1078</id>
    </mitre>
    <group>nhi_spire_pid_svid_burst,</group>
  </rule>

  <!-- Same PID obtained multiple SVIDs — selector spoofing / overlapping entries
       FIX: Lowered level 14→10, increased frequency 2→3, reduced timeframe 300→120.
       This is a TRIAGE rule — Wazuh cannot check distinct SPIFFE IDs.
       For confirmed multi-identity detection see script-based rule 101007. -->
  <rule id="101006" level="10" frequency="3" timeframe="120">
    <if_matched_group>nhi_spire_svid_fetch</if_matched_group>
    <same_field>id</same_field>
    <description>NHI-SPIRE: TRIAGE - Same PID $(id) multiple SVID events - verify SPIFFE IDs differ (see 101007 for confirmed detection)</description>
    <mitre>
      <id>T1098</id>
      <id>T1134</id>
    </mitre>
    <group>nhi_spire_multi_identity,</group>
  </rule>

  <!-- ===== Script-Based Detection (101007-101009) ===== -->
  <!-- These rules match output from spire_identity_monitor.py which
       implements detection logic Wazuh rules cannot express natively:
       distinct SPIFFE ID counting per PID and burst detection. -->

  <!-- CONFIRMED: Multiple distinct SPIFFE identities for same PID -->
  <rule id="101007" level="14">
    <decoded_as>nhi-spire-detect</decoded_as>
    <match>type=multi_identity</match>
    <description>NHI-SPIRE: PID $(id) has $(status) distinct SPIFFE identities - CONFIRMED selector spoofing [$(url)]</description>
    <mitre>
      <id>T1098</id>
      <id>T1134</id>
    </mitre>
    <group>nhi_spire_confirmed_spoofing,</group>
  </rule>

  <!-- CONFIRMED: SVID request burst from single PID -->
  <rule id="101008" level="12">
    <decoded_as>nhi-spire-detect</decoded_as>
    <match>type=svid_burst</match>
    <description>NHI-SPIRE: PID $(id) made $(extra_data) SVID requests in 5 min - credential harvesting</description>
    <mitre>
      <id>T1552.007</id>
      <id>T1078</id>
    </mitre>
    <group>nhi_spire_confirmed_burst,</group>
  </rule>

  <!-- ===== Registration Entry & Selector Anomalies (101020-101039) ===== -->

  <!-- Registration entry created
       Matches: SPIRE Server standard logs AND audit logs (audit_log_enabled=true)
       Audit format: {"type":"audit","method":"CreateEntry","service":"entry.v1.Entry",...} -->
  <rule id="101020" level="12">
    <decoded_as>nhi-spire-server</decoded_as>
    <match type="pcre2">spire-server\s+entry\s+create|CreateEntry|BatchCreateEntry|"method":"entry\.v1\.Entry/BatchCreateEntry"|"method":"CreateEntry".*"service":"entry</match>
    <description>NHI-SPIRE: Registration entry created - verify authorization</description>
    <mitre>
      <id>T1098</id>
      <id>T1136</id>
    </mitre>
    <group>nhi_spire_entry_create,</group>
  </rule>

  <!-- Registration with weak/spoofable selectors -->
  <rule id="101021" level="12">
    <if_sid>101020</if_sid>
    <match type="pcre2">k8s:node-name|unix:uid:0|docker:label:.*=|unix:gid:0|-selector\s+"?unix:uid:0</match>
    <description>NHI-SPIRE: Registration with weak/spoofable selectors - impersonation risk</description>
    <mitre>
      <id>T1098</id>
      <id>T1078</id>
    </mitre>
    <group>nhi_spire_weak_selector,</group>
  </rule>

  <!-- Registration entry modified or deleted -->
  <rule id="101022" level="12">
    <decoded_as>nhi-spire-server</decoded_as>
    <match type="pcre2">spire-server\s+entry\s+(update|delete)|UpdateEntry|DeleteEntry|BatchDeleteEntry|BatchUpdateEntry</match>
    <description>NHI-SPIRE: Registration entry modified or deleted</description>
    <mitre>
      <id>T1098</id>
      <id>T1531</id>
    </mitre>
    <group>nhi_spire_entry_modify,</group>
  </rule>

  <!-- ===== Agent & Trust Boundary Attacks (101040-101059) ===== -->

  <!-- Agent re-attestation event (server-side audit log) -->
  <rule id="101040" level="10">
    <decoded_as>nhi-spire-server</decoded_as>
